# Crowdly — root environment variables for docker-compose.
# Copy this file to .env and adjust as needed.

# ─── Postgres ────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=campus

# ─── Backend ─────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_NAME=Crowd Management API
APP_ENV=development
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60

# ─── Seed (initial admin) ────────────────────────────
# Used by `python -m app.seed` on container start. Only takes effect on the
# first launch; an admin already in the DB will not be re-created.
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=123456789
