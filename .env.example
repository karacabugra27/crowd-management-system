# ============================================================
# InfluxDB
# ============================================================
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=campus-super-secret-token
INFLUXDB_ORG=campus
INFLUXDB_BUCKET=occupancy
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=campus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://postgres:1234@postgres:5432/campus

# ============================================================
# Redis (Celery broker / result backend)
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ============================================================
# Firebase Cloud Messaging
# ============================================================
# Path mounted inside backend & celery worker containers
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ============================================================
# Application URLs
# ============================================================
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://localhost:3000

# ============================================================
# Collector
# ============================================================
COLLECTOR_INTERVAL_SECONDS=60
COLLECTOR_USE_MOCK=true

# ============================================================
# Notifications
# ============================================================
NOTIFICATION_COOLDOWN_MINUTES=15
NOTIFICATION_CHECK_INTERVAL_SECONDS=60

# ============================================================
# Misc
# ============================================================
LOG_LEVEL=INFO
TIMEZONE=Europe/Istanbul
